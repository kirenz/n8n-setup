# Konfigurations-Template für die n8n-Hetzner-Instanz.
#
# Im Produktivbetrieb wird .env vom Cloud-Init beim ersten Boot automatisch
# aus diesem Template erzeugt. Geheimnisse (POSTGRES_PASSWORD,
# N8N_ENCRYPTION_KEY) werden mit openssl rand generiert; DOMAIN wird aus der
# Server-IP abgeleitet (${IP}.sslip.io, mit Bindestrich-Variante als Fallback
# für ältere DNS-Resolver).
#
# Wer .env manuell editiert: NIEMALS einchecken (steht in .gitignore).

# =============================================================================
# DOMAIN UND TLS
# =============================================================================

# DNS-Name, unter dem n8n erreichbar ist. sslip.io löst jede Subdomain
# automatisch auf die enthaltene IP auf – kein eigenes DNS-Setup nötig.
# Beispiel: 1-2-3-4.sslip.io für Server mit IP 1.2.3.4.
DOMAIN=__DOMAIN__

# =============================================================================
# DATENBANK (POSTGRES)
# =============================================================================

POSTGRES_USER=n8n
POSTGRES_DB=n8n
# Wird vom Cloud-Init mit `openssl rand -base64 32` generiert.
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__

# =============================================================================
# N8N – CREDENTIAL-VERSCHLÜSSELUNG
# =============================================================================

# >>> EXTREM WICHTIG <<<
# Dieser Schlüssel verschlüsselt ALLE in n8n gespeicherten Credentials
# (API-Keys, OAuth-Tokens etc.). Bei Verlust sind alle Credentials
# unwiderruflich verloren – Workflows müssten neu verknüpft werden.
#
# scripts/backup.sh sichert diese .env-Datei mit. Vor dem Löschen des Servers
# muss sie auf einen sicheren lokalen Ort kopiert werden (siehe
# docs/server-loeschen.md).
#
# Wird vom Cloud-Init mit `openssl rand -hex 32` generiert.
N8N_ENCRYPTION_KEY=__N8N_ENCRYPTION_KEY__

# =============================================================================
# N8N – URL-KONFIGURATION
# =============================================================================

# Hostname-Teil der URL (ohne Schema, ohne Port).
N8N_HOST=__DOMAIN__
# Schema: hinter Caddy ist immer https.
N8N_PROTOCOL=https
# Vollständige Webhook-Basis-URL. Wichtig für eingehende Webhooks und
# OAuth-Callbacks externer Dienste (Google, Slack, GitHub …).
WEBHOOK_URL=https://__DOMAIN__/

# =============================================================================
# ZEITZONE
# =============================================================================

# Wirkt auf Cron-/Schedule-Trigger und auf Log-Timestamps.
GENERIC_TIMEZONE=Europe/Berlin
TZ=Europe/Berlin

# =============================================================================
# TELEMETRIE UND OUTBOUND-CALLS
# =============================================================================
#
# Pädagogische Anforderung: Studierende sollen lernen, jede einzelne
# Telemetrie-Option bewusst zu prüfen, statt Defaults blind zu übernehmen.
# Im Kurs-Default sind alle drei deaktiviert. Für eigene produktive Setups
# kann eine andere Wahl sinnvoll sein – Begründungen siehe Kommentare unten
# und docs/dsgvo.md.

# Anonyme Telemetrie über App-Nutzung, Feature-Verwendung, Crashes.
# Kurs-Default: false – klassisches Tracking, sollte bewusst entschieden
# werden. Eigennutzung: weiterhin false empfohlen.
N8N_DIAGNOSTICS_ENABLED=false

# Ausgehende Calls zu n8n.io zur Prüfung neuer Versionen.
# Kurs-Default: false – damit Studierende über jede Outbound-Verbindung
# aktiv nachdenken. Eigennutzung: true durchaus sinnvoll, weil
# Security-Patches dann sichtbar werden.
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# Onboarding-Wizard, der Profilangaben (Rolle, Unternehmensgröße, Tool-Stack)
# erfragt und an n8n.io übermittelt.
# Kurs-Default: false – Studierenden-Profile sollen nicht ungefragt an Dritte
# fließen. Eigennutzung: true ist ein fairer Tausch (relevantere Templates),
# kein echtes Datenschutz-Problem.
N8N_PERSONALIZATION_ENABLED=false

# =============================================================================
# IMAGE-TAGS (für reproduzierbare Updates)
# =============================================================================
#
# Wer aktualisieren will: Tag hier hochziehen, dann scripts/update.sh.
# Vor jedem Semester sollte die aktuelle Stable-Version geprüft werden.

N8N_IMAGE_TAG=2.20.6
POSTGRES_IMAGE_TAG=16.13-alpine3.23
CADDY_IMAGE_TAG=2.11.2-alpine
